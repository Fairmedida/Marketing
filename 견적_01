    <!-- Script / Interaction logic -->
    <script>
        // Global State for Interactive Calculator
        let activePackage = 'standard';
        let basePrice = 800000;

        // Initialize Icons
        lucide.createIcons();

        // Package Selector function
        function selectPackage(pkg, price) {
            activePackage = pkg;
            basePrice = price;

            // Highlight chosen package button
            const buttons = document.querySelectorAll('.package-btn');
            buttons.forEach(btn => {
                if (btn.getAttribute('data-package') === pkg) {
                    btn.classList.remove('border-slate-800', 'bg-slate-900', 'text-slate-300');
                    btn.classList.add('border-brand-500', 'bg-brand-900/30');
                } else {
                    btn.classList.remove('border-brand-500', 'bg-brand-900/30');
                    btn.classList.add('border-slate-800', 'bg-slate-900', 'text-slate-300');
                }
            });

            calculateQuote();
        }

        // Real-time calculation logic
        function calculateQuote() {
            const cameras = parseInt(document.getElementById('camera-range').value);
            const hours = parseInt(document.getElementById('hours-range').value);

            // Update range UI text
            document.getElementById('camera-val').innerText = `${cameras}대`;
            document.getElementById('hours-val').innerText = `${hours}시간`;

            // Calculate item costs
            const cameraPrice = (cameras - 1) * 200000; // Base package includes 1 camera
            const hourPrice = (hours - 1) * 100000;    // Base package includes 1 hour

            let optionPrice = 0;
            const hasPip = document.getElementById('opt-pip').checked;
            const hasCaption = document.getElementById('opt-caption').checked;
            const hasMultistream = document.getElementById('opt-multistream').checked;

            if (hasPip) optionPrice += 100000;
            if (hasCaption) optionPrice += 150000;
            if (hasMultistream) optionPrice += 100000;

            const totalPrice = basePrice + cameraPrice + hourPrice + optionPrice;

            // Update Summary Panels
            document.getElementById('summary-base').innerText = `${basePrice.toLocaleString()}원`;
            document.getElementById('summary-cameras').innerText = `${cameraPrice.toLocaleString()}원`;
            document.getElementById('summary-hours').innerText = `${hourPrice.toLocaleString()}원`;
            document.getElementById('summary-options').innerText = `${optionPrice.toLocaleString()}원`;
            document.getElementById('total-price').innerText = totalPrice.toLocaleString();
        }

        // Handle quote form submission
        function submitQuote(event) {
            event.preventDefault();

            const orgName = document.getElementById('org-name').value;
            const contactName = document.getElementById('contact-name').value;
            const hours = document.getElementById('hours-range').value;
            const total = document.getElementById('total-price').innerText;

            // Fill details in success modal
            document.getElementById('modal-org-name').innerText = `${orgName} (${contactName} 님)`;
            document.getElementById('modal-hours').innerText = `${hours}시간 중계 진행`;
            document.getElementById('modal-total-price').innerText = `${total} 원`;

            // Show modal
            document.getElementById('success-modal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('success-modal').classList.add('hidden');
            document.getElementById('lead-form').reset();
            // Reset to default standard state
            selectPackage('standard', 800000);
        }

        // Toggle FAQ Accordion
        function toggleFaq(num) {
            const answer = document.getElementById(`faq-ans-${num}`);
            const icon = document.getElementById(`faq-icon-${num}`);
            
            if (answer.classList.contains('hidden')) {
                answer.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                answer.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }

        // Floating Chat simulation
        function toggleChat() {
            const chatBox = document.getElementById('chat-bubble');
            const launcherIcon = document.getElementById('chat-launcher-icon');
            
            if (chatBox.classList.contains('hidden')) {
                chatBox.classList.remove('hidden');
                launcherIcon.setAttribute('data-lucide', 'x');
            } else {
                chatBox.classList.add('hidden');
                launcherIcon.setAttribute('data-lucide', 'message-square');
            }
            lucide.createIcons();
        }

        // Mock chat system
        function sendChatMessage(event) {
            event.preventDefault();
            const input = document.getElementById('chat-input');
            const message = input.value.trim();
            if (!message) return;

            const chatBody = document.getElementById('chat-body');

            // User Message
            const userMsgDiv = document.createElement('div');
            userMsgDiv.className = "bg-brand-600 p-3 rounded-l-xl rounded-br-xl text-white max-w-[85%] self-end";
            userMsgDiv.innerText = message;
            chatBody.appendChild(userMsgDiv);
            
            input.value = '';
            chatBody.scrollTop = chatBody.scrollHeight;

            // Simple Auto Bot Response in 1 second
            setTimeout(() => {
                const botMsgDiv = document.createElement('div');
                botMsgDiv.className = "bg-slate-800 p-3 rounded-r-xl rounded-bl-xl text-slate-300 max-w-[85%] self-start";
                botMsgDiv.innerText = "메시지를 확인했습니다! 담당 피디가 신속히 상세 조정을 도와드릴 수 있도록, '실시간 견적기'에 상담 정보를 남겨주시거나 대표 연락처로 유선 전화 주시면 더욱 정밀한 설명이 즉각 가능합니다. 감사합니다.";
                chatBody.appendChild(botMsgDiv);
                chatBody.scrollTop = chatBody.scrollHeight;
            }, 1000);
        }

        // Run calculation once on load
        window.onload = function() {
            calculateQuote();
        }
    </script>
